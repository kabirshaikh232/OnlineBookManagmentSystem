<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- ══════════════════════════════════════════
       DATABASE
  ══════════════════════════════════════════ -->
  <connectionStrings>
    <add name="DBCS" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=OnlineBookStoreDB;Integrated Security=True" providerName="System.Data.SqlClient" />
    <add name="BookShelfDB" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=OnlineBookStoreDB;Integrated Security=True" providerName="System.Data.SqlClient" />
  </connectionStrings>
  <!-- ══════════════════════════════════════════
       RAZORPAY — updated test keys
  ══════════════════════════════════════════ -->
  <appSettings>
    <add key="RazorpayKey" value="rzp_test_ShxLi3czJEQeWd" />
    <add key="RazorpaySecret" value="Nq6q4B62meukWeNo1Sl7buRV" />
  </appSettings>
  <!-- ══════════════════════════════════════════
       ASP.NET
  ══════════════════════════════════════════ -->
  <system.web>
    <!-- ✅ debug true for development -->
    <compilation targetFramework="4.5" />
    <!-- 🔐 Fix TLS + hide version header -->
    <httpRuntime targetFramework="4.5" enableVersionHeader="false" />
    <!-- 🔐 Session timeout 20 mins -->
    <sessionState timeout="20" mode="InProc" />
    <!-- 🔐 Hide server errors -->
    <customErrors mode="On" defaultRedirect="Login.aspx">
      <error statusCode="403" redirect="Login.aspx" />
      <error statusCode="404" redirect="Login.aspx" />
      <error statusCode="500" redirect="Login.aspx" />
    </customErrors>
    <authentication mode="None" />
  </system.web>
  <!-- ══════════════════════════════════════════
       IIS / SECURITY HEADERS
  ══════════════════════════════════════════ -->
  <system.webServer>
    <security>
      <requestFiltering>
        <!-- 🔐 Block requests over 4MB -->
        <requestLimits maxAllowedContentLength="4194304" />
      </requestFiltering>
    </security>
    <httpProtocol>
      <customHeaders>
        <!-- 🔐 Hide ASP.NET identity -->
        <remove name="X-Powered-By" />
        <!-- 🔐 Block clickjacking -->
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <!-- 🔐 Block XSS -->
        <add name="X-XSS-Protection" value="1; mode=block" />
        <!-- 🔐 Block MIME sniffing -->
        <add name="X-Content-Type-Options" value="nosniff" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
